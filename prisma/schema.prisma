// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id              String   @id @default(cuid())
  zipCode         String
  insuranceType   String   // farm, home, auto, life, renters
  email           String
  firstName       String?
  lastName        String?
  phone           String?
  farmSize        Float?   // in acres, for farm insurance
  propertyValue   Float?   // for home/farm insurance
  vehicleMake     String?  // for auto insurance
  vehicleModel    String?  // for auto insurance
  vehicleYear     Int?     // for auto insurance
  coverageAmount  Float?
  status          String   @default("pending") // pending, processing, completed, failed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  quotes          InsuranceQuote[]
}

model InsuranceQuote {
  id              String   @id @default(cuid())
  quoteRequestId  String
  provider        String   // insurance company name
  premium         Float    // monthly or annual premium
  deductible      Float?
  coverageDetails String?  // JSON string with coverage details
  createdAt       DateTime @default(now())

  // Advanced fields for the new quote algorithm
  insurerId       String?  // internal insurer ID
  rankScore       Float?   // calculated ranking score
  savingsVsAverage Float?  // percentage savings vs average
  isBestValue     Boolean  @default(false)
  isAnomaly       Boolean  @default(false) // was this quote filtered as an anomaly?

  // Relations
  quoteRequest    QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
}

model Insurer {
  id              String   @id @default(cuid())
  name            String
  insurerCode     String   @unique // external code from carrier
  baseRateMultiplier Float
  reputationScore Float
  marketShare     Float
  isActive        Boolean  @default(true)
  apiEndpoint     String?
  lastSynced      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AnonymizedQuoteData {
  id              String   @id @default(cuid())
  userIdHash      String   // anonymized user ID
  zipCode         String
  state           String
  ageRange        String
  riskScore       Float
  insuranceType   String
  averagePremium  Float
  lowestPremium   Float
  highestPremium  Float
  quotesCount     Int
  timestamp       DateTime @default(now())
}

model QuoteAnalytics {
  id              String   @id @default(cuid())
  date            DateTime
  insuranceType   String
  state           String
  totalQuotes     Int
  averagePremium  Float
  medianPremium   Float
  minPremium      Float
  maxPremium      Float
  createdAt       DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
